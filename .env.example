# ============================================
# weather-bot 环境变量配置
# 复制此文件为 .env 并填入你的密钥
# ============================================

# --- OpenWeatherMap API Key (推荐，免费100万次/月) ---
# 注册地址: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# --- 和风天气 API Key (备选，免费1000次/天) ---
# 注册地址: https://dev.qweather.com/
# QWATHER_API_KEY=your_qweather_api_key_here

# --- 数据源选择: "openweathermap" | "qweather" | "ogimet" | "synthetic" ---
# synthetic = 模拟数据，无需API Key，适合测试
STATION_DATA_SOURCE=synthetic

# --- 背景场: "era5" | "gfs" | "none" ---
# ERA5需要CDS API Key (~/.cdsapirc)
# GFS免费但需要能访问NOAA NOMADS
BACKGROUND_SOURCE=none

# --- nonebot2 配置 ---
HOST=127.0.0.1
PORT=8080
COMMAND_START=["/", "。"]
SUPERUSERS=[""]

# --- NapCatQQ WebSocket 连接令牌 (需与napcat.json中一致) ---
ONEBOT_ACCESS_TOKEN=weather-bot-token
